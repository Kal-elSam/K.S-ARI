# Proyecto Sentry del dashboard (frontend), distinto al de la API. sentry.io → Project → Client Keys (DSN).
# Inicialización en instrumentation-client.ts, sentry.server.config.ts y sentry.edge.config.ts.
NEXT_PUBLIC_SENTRY_DSN=

# Opcional: etiqueta de entorno (si no usas VERCEL_ENV).
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Build en Vercel: subida de source maps (Settings → Auth Tokens; org y slug del proyecto).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
